{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "types": ["vite/client"],
    "paths": {
      "@server/*": ["../src/*"]
    }
  },
  "include": ["src", "styles"]
}
