{
  "name": "heimdal",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json && tsc -p web/tsconfig.json",
    "test": "vitest run --project web --project server",
    "test:watch": "vitest --project web --project server",
    "test:integration": "vitest run --project integration",
    "test:smoke": "vitest run --project smoke",
    "test:all": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.14",
    "@fastify/cookie": "^11.1.1",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "ai": "^7.0.27",
    "argon2": "^0.44.0",
    "fastify": "^5.10.0",
    "imapflow": "^1.4.3",
    "iso-639-1": "^3.1.6",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/json-schema": "^7.0.15",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "testcontainers": "^12.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
