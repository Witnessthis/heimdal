{
  "name": "heimdal",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "fastify": "^4.28.0",
    "imapflow": "^1.4.3",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
